# Option B: Custom SMTP (Outlook, Yahoo, business email, etc.)
#   Fill these in + keep EMAIL_USER and EMAIL_PASS above
#
# Outlook / Hotmail:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=false
#
# Yahoo Mail:
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=465
# SMTP_SECURE=true
#
# Custom business email (e.g. cPanel/Namecheap/GoDaddy):
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=465
# SMTP_SECURE=true
